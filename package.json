{
  "name": "@larelabs/refinery-mcp",
  "version": "0.1.5",
  "description": "MCP server for cleaning raw HTML into LLM-ready text with Refinery.",
  "mcpName": "io.github.LareLabs/refinery-mcp",
  "type": "module",
  "bin": {
    "refinery-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "server.json",
    "llms-install.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "inspect": "npx @modelcontextprotocol/inspector node dist/index.js",
    "smoke": "node examples/smoke.mjs"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "html",
    "rag",
    "llm",
    "apify",
    "web-scraping"
  ],
  "author": "LareLabs",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "latest",
    "apify-client": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "tsx": "latest",
    "typescript": "latest"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LareLabs/refinery-mcp.git"
  },
  "homepage": "https://larelabs.github.io/refinery-mcp/",
  "bugs": {
    "url": "https://github.com/LareLabs/refinery-mcp/issues"
  }
}
